NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

ADMIN_USERNAME=adminusman
ADMIN_PASSWORD=replace-with-a-strong-password
AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters

# Added by the Vercel Neon integration.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Added by the connected Vercel Blob store.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me

# Optional external chatbot backend. Do not use localhost on Vercel.
CHATBOT_API_URL=https://your-chatbot-api.example.com
CHATBOT_ADMIN_KEY=replace-with-a-secret-chatbot-admin-key

NEXT_PUBLIC_EMAILJS_SERVICE_ID=replace-with-emailjs-service-id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=replace-with-emailjs-template-id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=replace-with-emailjs-public-key
